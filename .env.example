# =============================================================================
# Agent Worker Environment Variables
# =============================================================================
# Copy this to .env and fill in your values

# VPS Connection
VPS_BASE_URL=https://blakecollins.dev
VPS_API_KEY=your_api_key_here

# LM Studio Connection (from inside Docker)
OPENAI_API_BASE=http://host.docker.internal:1234/v1
OPENAI_MODEL=local-model
OPENAI_API_KEY=not-needed

# Must match LM Studio's own "Num Parallel Slots" server setting (Developer
# tab > server settings) — this is the real ceiling on how many LLM calls
# can actually run at once; raising it past LM Studio's real value just
# queues client-side with no benefit. With TRACE_ENABLED=1, check the traced
# wait_s field on llm_call events: consistently high means turn this UP to
# match whatever LM Studio is set to; consistently near-zero means you're
# already at the ceiling.
MAX_PARALLEL_LLM_CALLS=4

# Workspace
WORK_DIR=/workspace
TIMEZONE=Pacific/Auckland

# Full debug tracing — off by default (no file I/O overhead). Set to 1 for a
# deliberate test run to capture every LLM prompt/response, full page
# scrapes, and persona/memory decisions to /workspace/traces/<task_id>.jsonl.
# Restart the worker after changing this — read once at process start.
TRACE_ENABLED=0

# Polling interval (seconds)
POLL_INTERVAL=3

# Sender identity (used in email drafts and signatures)
SENDER_NAME=Your Name
SENDER_TITLE=Your Job Title
SENDER_WEBSITE=yourwebsite.com
SENDER_BIO=Brief description of what you do and the value you offer
